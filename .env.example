# =============================================================================
# ONGC Knowledge Hub — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to Git.
# =============================================================================

# --- Ollama (Local LLM Runtime) ----------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120                   # seconds to wait for LLM response

# --- ChromaDB (Vector Store) -------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma     # persistent storage path

# --- FastAPI Server ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                      # set to false in production

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# --- OCR (Week 2) ------------------------------------------------------------
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Security (Week 4) -------------------------------------------------------
# SECRET_KEY=changeme                # JWT signing key — set before deployment
# ALLOWED_ORIGINS=http://localhost:3000
