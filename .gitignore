# =============================================================================
# ONGC Knowledge Hub — .gitignore
# =============================================================================

# --- Environment & Secrets ---------------------------------------------------
.env
.env.local
.env.*.local

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Virtual Environments ----------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Distribution / Packaging ------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# --- Testing -----------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
*.xml

# --- IDE & OS ----------------------------------------------------------------
.idea/
.vscode/
*.DS_Store
Thumbs.db

# --- Data & Vector Store (large files, machine-local) -----------------------
data/chroma/
data/*.pdf
data/*.docx
data/*.xlsx
data/*.db
*.bin
*.onnx

# --- Docker -----------------------------------------------------------------
docker/*.env

# --- Logs & Reports -----------------------------------------------------------
*.log
logs/
security_report.txt
